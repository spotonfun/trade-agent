# ═══════════════════════════════════════════════
# TRADE-AGENT – zmienne środowiskowe
# Skopiuj do .env i uzupełnij prawdziwymi wartościami
# NIGDY nie commituj .env do git!
# ═══════════════════════════════════════════════

# true = tylko analiza, zero zleceń do brokera
DRY_RUN=true


# ── PostgreSQL ──────────────────────────────────
POSTGRES_DB=tradeagent
POSTGRES_USER=tradeuser
POSTGRES_PASSWORD=zmien_na_silne_haslo_123
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Redis ───────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=zmien_na_silne_haslo_redis

# ── Ollama ──────────────────────────────────────
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.2

# ── Interactive Brokers (IBKR) ──────────────────
# Konto na ibkr.com → paper trading account
IBKR_USERNAME=twoj_ibkr_login
IBKR_PASSWORD=twoje_ibkr_haslo
IBKR_TRADING_MODE=paper          # paper lub live – zacznij od paper!
IBKR_PORT=4002                   # 4002=paper, 4001=live
IBKR_CLIENT_ID=1

# ── Reddit API ──────────────────────────────────
# reddit.com/prefs/apps → "create app" → script
REDDIT_CLIENT_ID=twoj_reddit_client_id
REDDIT_CLIENT_SECRET=twoj_reddit_client_secret
REDDIT_USER_AGENT=trade-agent/1.0

# ── Telegram Bot ────────────────────────────────
# t.me/BotFather → /newbot → skopiuj token
# Swoje chat_id: t.me/userinfobot
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=123456789

# ── NewsAPI (opcjonalne, darmowy plan = 100 req/dzień) ──
# newsapi.org → register → API key
NEWSAPI_KEY=twoj_newsapi_key

# ── Alpha Vantage (opcjonalne, darmowy plan) ────
# alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=twoj_alpha_vantage_key

# ── Grafana ─────────────────────────────────────
GRAFANA_PASSWORD=zmien_na_silne_haslo_grafana

# ── pgAdmin ─────────────────────────────────────
PGADMIN_EMAIL=admin@tradeagent.local
PGADMIN_PASSWORD=zmien_na_silne_haslo_pgadmin

# ── Parametry systemu ───────────────────────────
KAPITAL_PORTFELA=10000           # PLN/USD – twój kapitał
MAX_POZYCJA_PROCENT=8
MAX_DRAWDOWN_PROCENT=15
HUMAN_APPROVAL=true              # true = czekaj na zatwierdzenie przez Telegram
CYKL_GODZINY=4                  # co ile godzin analizuj
TICKERY=AAPL,NVDA,MSFT,SPY      # lista przez przecinek